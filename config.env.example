# Feishuctral - 飞书 Claude Code 桥接器配置
# 复制到 ~/.claude-to-im/config.env 并编辑

# 运行时后端: claude | codex | auto
CTI_RUNTIME=claude

# 启用的通道（飞书专用）
CTI_ENABLED_CHANNELS=feishu

# 默认工作目录（Claude Code 会话的工作路径）
CTI_DEFAULT_WORKDIR=/path/to/your/project

# 默认模型（可选 — 不设则继承 Claude Code 默认模型）
# CTI_DEFAULT_MODEL=

# 默认模式: code | plan | ask
CTI_DEFAULT_MODE=code

# ── 飞书 / Lark ──
# 从 https://open.feishu.cn/app → 你的应用 → 凭证与基础信息 获取
CTI_FEISHU_APP_ID=your-app-id
CTI_FEISHU_APP_SECRET=your-app-secret
# 国际版 Lark 用户改为 https://open.larksuite.com
CTI_FEISHU_DOMAIN=https://open.feishu.cn
# 可选：限制可使用的用户（open_id，逗号分隔），留空允许所有人
# CTI_FEISHU_ALLOWED_USERS=

# ── 第三方 API 提供商（可选）──
# 如果你通过第三方 API 使用 Claude，设置以下变量
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your-auth-token

# ── 权限 ──
# 自动批准所有工具调用（适合仅自己使用的飞书机器人）
# ⚠️ 仅在受信任、受控的环境中使用
# CTI_AUTO_APPROVE=true
